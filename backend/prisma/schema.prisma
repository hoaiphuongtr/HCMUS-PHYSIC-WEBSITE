generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum Language {
  EN
  VI
}

enum ContentStatus {
  DRAFT
  PENDING
  SCHEDULED
  PUBLISHED
  REJECTED
}

enum MediaType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  TEMPLATE_SNAPSHOT
}

enum PostCategory {
  EDUCATIONAL_NEWS
  SCIENTIFIC_INFORMATION
  RECRUITMENT
  EVENT
  SCHOLARSHIP
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum TranslationProvider {
  LARA
  DEEPSEEK
  GROK
  MANUAL
}

enum BlockType {
  PARAGRAPH
  HEADING
  IMAGE
  VIDEO
  LINK
  REGISTRATION_FORM
  QUOTE
  LIST
  DIVIDER
  EMBED
}

enum VerificationCodeType {
  REGISTER
  FORGOT_PASSWORD
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

enum WidgetCategory {
  FEED_COMPONENTS
  UTILITY_INFO
  CONTENT
  NAVIGATION
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String?
  lastName          String?
  password          String?
  avatarUrl         String?
  googleId          String?   @unique
  role              Role      @default(USER)
  isActive          Boolean   @default(true)
  hasSetPreferences Boolean   @default(false)
  phone             String?
  position          String?
  bio               String?
  departmentId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  department          Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  preference          UserPreference?
  sessions            Session[]
  accounts            Account[]
  templates           Template[]
  posts               Post[]
  postsApproved       Post[]            @relation("PostApprovedBy")
  postReactions       PostReaction[]
  postComments        PostComment[]
  postTranslations    PostTranslation[]
  media               Media[]
  notifications       Notification[]
  faqItems            FAQ[]
  faqUpdated          FAQ[]             @relation("FAQUpdatedBy")
  chatbotTraining     ChatbotTraining[]
  auditLogs           AuditLog[]
  pageLayouts         PageLayout[]

  @@index([role])
  @@index([email])
  @@index([googleId])
  @@index([departmentId])
}

model UserPreference {
  id                   String                @id @default(cuid())
  userId               String                @unique
  categories           PostCategory[]
  tags                 String[]
  notificationChannels NotificationChannel[] @default([EMAIL, IN_APP])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model VerificationCode {
  id        String               @id @default(cuid())
  email     String
  code      String
  type      VerificationCodeType
  expiresAt DateTime
  createdAt DateTime             @default(now())

  @@unique([email, type])
  @@index([expiresAt, email])
}

model Department {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@index([slug])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  structure   Json
  isActive    Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  snapshotId  String?  @unique

  createdByUser User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  snapshot      Media? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  posts         Post[]

  @@index([createdBy])
  @@index([isActive])
}

model Post {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  category        PostCategory
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  rejectedAt      DateTime?
  rejectReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  approvedBy      String?
  templateId      String?
  eventStartAt    DateTime?
  eventEndAt      DateTime?
  eventLocation   String?
  eventSpeakers   Json?
  registrationUrl String?
  metadata        Json?
  aiSummary       String?

  createdByUser  User              @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  approvedByUser User?             @relation("PostApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  template       Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contentBlocks  ContentBlock[]
  translations   PostTranslation[]
  reactions      PostReaction[]
  comments       PostComment[]
  postTags       PostTag[]
  media          PostMedia[]
  seoMetadata    SEOMetadata?

  @@index([status])
  @@index([category])
  @@index([createdBy])
  @@index([publishedAt])
  @@index([scheduledAt])
  @@index([slug])
  @@index([eventStartAt])
}

model ContentBlock {
  id        String    @id @default(cuid())
  postId    String
  type      BlockType
  content   Json
  order     Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([order])
}

model PostTranslation {
  id          String              @id @default(cuid())
  postId      String
  language    Language
  title       String
  excerpt     String?
  blocks      Json
  aiSummary   String?
  provider    TranslationProvider
  isConfirmed Boolean             @default(false)
  confirmedBy String?
  confirmedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  post          Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  confirmedUser User? @relation(fields: [confirmedBy], references: [id], onDelete: SetNull)

  @@unique([postId, language])
  @@index([postId])
  @@index([language])
}

model PostReaction {
  id        String       @id @default(cuid())
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  PostComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model Widget {
  id            String         @id @default(cuid())
  type          String         @unique
  name          String
  description   String?
  category      WidgetCategory
  icon          String?
  configSchema  Json
  defaultConfig Json           @default("{}")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  instances WidgetInstance[]

  @@index([category])
  @@index([isActive])
}

model WidgetInstance {
  id           String   @id @default(cuid())
  widgetId     String
  pageLayoutId String
  config       Json     @default("{}")
  order        Int
  row          Int      @default(0)
  colSpan      Int      @default(12)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  widget     Widget     @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  pageLayout PageLayout @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)

  @@index([pageLayoutId])
  @@index([widgetId])
  @@index([order])
}

model PageLayout {
  id                String    @id @default(cuid())
  name              String
  slug              String
  description       String?
  puckData          Json?
  publishedPuckData Json?
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  scheduledAt       DateTime?
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdByUser User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  widgets       WidgetInstance[]
  seoMetadata   SEOMetadata?

  @@index([slug])
  @@index([isPublished])
  @@index([createdBy])
  @@index([scheduledAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postTags  PostTag[]
  mediaTags MediaTag[]

  @@index([slug])
}

model PostTag {
  postId    String
  tagId     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model MediaTag {
  mediaId   String
  tagId     String
  createdAt DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mediaId, tagId])
  @@index([tagId])
}

model Media {
  id        String    @id @default(cuid())
  name      String
  type      MediaType
  url       String
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  alt       String?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  createdByUser    User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  templateSnapshot Template?
  postMedia        PostMedia[]
  mediaTags        MediaTag[]

  @@index([createdBy])
  @@index([type])
}

model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  mediaId   String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaId])
  @@index([mediaId])
}

model SEOMetadata {
  id              String   @id @default(cuid())
  postId          String?  @unique
  pageLayoutId    String?  @unique
  metaTitle       String?
  metaDescription String?
  keywords        String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post       Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  pageLayout PageLayout? @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  channel   NotificationChannel
  isRead    Boolean             @default(false)
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Subscription {
  id         String    @id @default(cuid())
  email      String    @unique
  visitorId  String?
  tagSlugs   String[]
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([visitorId])
}

model VisitorProfile {
  id          String   @id @default(cuid())
  tagWeights  Json     @default("{}")
  slugWeights Json     @default("{}")
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SlugVisit {
  id        String   @id @default(cuid())
  visitorId String
  slug      String
  createdAt DateTime @default(now())

  @@index([visitorId, slug])
  @@index([slug, createdAt])
}

model PostRead {
  id        String   @id @default(cuid())
  visitorId String
  postId    String
  createdAt DateTime @default(now())

  @@index([visitorId, postId])
  @@index([postId, createdAt])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdBy String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUser User              @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  updatedByUser User?             @relation("FAQUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  trainingData  ChatbotTraining[]

  @@index([isActive])
  @@index([category])
  @@index([createdBy])
}

model ChatbotTraining {
  id        String   @id @default(cuid())
  faqId     String?
  question  String
  answer    String
  context   String?
  language  Language
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUser User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  faq           FAQ? @relation(fields: [faqId], references: [id], onDelete: SetNull)

  @@index([language])
  @@index([isActive])
  @@index([createdBy])
  @@index([faqId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@index([action])
}

model AIConfig {
  id        String   @id @default(cuid())
  provider  String
  model     String
  purpose   String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  rateLimit Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, model, purpose])
  @@index([purpose])
  @@index([isActive])
}
