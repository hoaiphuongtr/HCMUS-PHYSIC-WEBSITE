{
  "name": "hcmus-physic-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:public": "pnpm --filter public dev",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:admin\" \"pnpm dev:public\"",
    "build:backend": "pnpm --filter backend build",
    "build:admin": "pnpm --filter admin build",
    "build:public": "pnpm --filter public build",
    "build": "pnpm build:backend && pnpm build:admin && pnpm build:public",
    "test:backend": "pnpm --filter backend test",
    "test:admin": "pnpm --filter admin test",
    "test:e2e:admin": "pnpm --filter admin test:e2e",
    "test:e2e:public": "pnpm --filter public test:e2e",
    "test:e2e": "pnpm test:e2e:admin && pnpm test:e2e:public",
    "playwright:install": "pnpm --filter admin exec playwright install chromium && pnpm --filter public exec playwright install chromium",
    "test": "pnpm test:backend && pnpm test:admin",
    "lint": "pnpm --filter backend lint && pnpm --filter admin lint && pnpm --filter public lint",
    "format": "pnpm --filter backend format && pnpm --filter admin format",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:seed": "pnpm --filter backend db:seed",
    "db:seed-widgets": "pnpm --filter backend db:seed-widgets",
    "db:seed-all": "pnpm --filter backend db:seed-all",
    "prisma:generate": "pnpm --filter backend prisma:generate",
    "prisma:migrate": "pnpm --filter backend prisma:migrate",
    "prisma:studio": "pnpm --filter backend prisma:studio",
    "tc": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@sentry/cli",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
